# =============================================================================
# Portugal Active — todas as variáveis que NÃO vão para o Git
# Copiar para .env (local) e preencher. No Render: Environment → mesmos nomes.
# Valores reais nunca em commits.
# =============================================================================

# ─── Infra (Render define PORT automaticamente) ─────────────────────────────
# NODE_ENV=production
# PORT=3000

# ─── Site ───────────────────────────────────────────────────────────────────
# URLs canónicas, sitemap, emails
SITE_URL=https://www.portugalactive.com

# ─── Guesty Open API — listings, availability, quotes ─────────────────────────
GUESTY_CLIENT_ID=
GUESTY_CLIENT_SECRET=
# Opcional: só se Guesty indicar outro host (default https://open-api.guesty.com)
# GUESTY_BASE_URL=https://open-api.guesty.com
# Após 429 no OAuth: máx. cooldown em ms (defaults 120000 / 180000 BE)
# GUESTY_MAX_OAUTH_COOLDOWN_MS=120000
# GUESTY_MAX_BE_OAUTH_COOLDOWN_MS=180000

# ─── Guesty Booking Engine — checkout / pagamento no site ───────────────────
GUESTY_BE_CLIENT_ID=
GUESTY_BE_CLIENT_SECRET=

# ─── Guesty webhooks (validação de assinatura no servidor) ──────────────────
GUESTY_WEBHOOK_SECRET=

# ─── Debug ops: POST /api/debug/guesty/reset-cooldown + header x-guesty-debug-secret
GUESTY_DEBUG_SECRET=

# ─── Stripe — mesma conta ligada ao Guesty; publishable vai no bundle ────────
STRIPE_PUBLISHABLE_KEY=
STRIPE_ACCOUNT_ID=

# ─── Base de dados (MySQL / TiDB); opcional em dev se não usares features DB ─
DATABASE_URL=

# ─── JWT — obrigatório em produção (env.ts falha o arranque sem isto) ────────
# Gerar: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# ─── Google OAuth — login de clientes ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OAuth / app (core env.ts + cliente) ───────────────────────────────────
# Servidor OAuth externo (se usado); VITE_* expostos ao browser no build
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=

# ─── Forge API (servidor + mapa no cliente) ─────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# ─── ActiveCampaign — CRM / newsletter ──────────────────────────────────────
ACTIVECAMPAIGN_API_URL=
ACTIVECAMPAIGN_API_KEY=
# ACTIVECAMPAIGN_CONTACTS_LIST_ID=
# ACTIVECAMPAIGN_NEWSLETTER_LIST_ID=

# ─── Guesty sync → GitHub (scripts / automação) ────────────────────────────
# GITHUB_PAT=
# GITHUB_REPO=owner/repo
# GITHUB_BRANCH=main

# ─── Admin (password) quando OAuth não está configurado; requer DATABASE_URL ─
ADMIN_PASSWORD=

# ─── Bókun — widget de booking para experiences ────────────────────────────
VITE_BOKUN_CHANNEL_UUID=

# ─── Prerender.io — serve HTML pré-renderizado a bots (Googlebot, etc.) ─────
# Criar conta em prerender.io, copiar o token. Só ativar em produção.
PRERENDER_TOKEN=

# ─── Analytics — injetado no build (Vite define __VITE_GA4_ID__) ────────────
VITE_GA4_ID=

# =============================================================================
# Notas Render / Vite
# - Variáveis VITE_* têm de existir no momento do BUILD estático (não só runtime).
# - Após alterar env no Render: redeploy ou “Clear build cache” se o front não atualizar.
# =============================================================================
