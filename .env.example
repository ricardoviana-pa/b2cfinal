# Guesty — sync (photos, texts) + live (availability, pricing, reservations)
GUESTY_CLIENT_ID=your_guesty_client_id
GUESTY_CLIENT_SECRET=your_guesty_client_secret
# Optional alternative auth (if provided, used as Bearer/API key first)
# GUESTY_API_KEY=your_guesty_api_key
# Optional base URL (defaults to Open API)
# GUESTY_BASE_URL=https://open-api.guesty.com
# Guesty webhook signature secret
# GUESTY_WEBHOOK_SECRET=your_webhook_secret

# Guesty Booking Engine API — for on-site checkout with payment (same as direct booking)
# Get from: Guesty → Growth → Distribution → Booking Engine API → Create API key
# GUESTY_BE_CLIENT_ID=your_be_client_id
# GUESTY_BE_CLIENT_SECRET=your_be_client_secret
# Stripe publishable key from the Stripe account connected to Guesty (pk_...)
# STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# Stripe connected account ID (acct_...) — from Guesty Financial > Payment processing
# STRIPE_ACCOUNT_ID=acct_xxx

# Optional: Database (for admin: leads, settings, blog). Not required for property display.
# DATABASE_URL=mysql://user:pass@host:3306/dbname

# Admin login — when OAuth not configured, use password (requires DATABASE_URL)
# ADMIN_PASSWORD=your_secure_password
