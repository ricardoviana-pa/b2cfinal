# =============================================================================
# Portugal Active — Environment Variables Reference
# Copy to .env and fill in values
# =============================================================================

# ─── Guesty — sync (photos, texts) + live (availability, pricing, reservations)
GUESTY_CLIENT_ID=your_guesty_client_id
GUESTY_CLIENT_SECRET=your_guesty_client_secret

# ─── Guesty Booking Engine API — on-site checkout with payment
GUESTY_BE_CLIENT_ID=your_guesty_be_client_id
GUESTY_BE_CLIENT_SECRET=your_guesty_be_client_secret

# ─── Stripe — same account connected to Guesty
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_ACCOUNT_ID=acct_xxx

# ─── Database — TiDB Cloud Serverless (MySQL compatible, Frankfurt region)
# Dashboard: https://tidbcloud.com — Cluster0 → portugalactive database
DATABASE_URL=mysql://user:pass@gateway01.eu-central-1.prod.aws.tidbcloud.com:4000/portugalactive?ssl={"rejectUnauthorized":true}

# ─── Google OAuth — customer login
# Console: https://console.cloud.google.com — project: portugal-active-491617
# Redirect URIs: http://localhost:3000/api/auth/google/callback, https://portugalactive.com/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret

# ─── Admin login (when OAuth not configured) — requires DATABASE_URL
ADMIN_PASSWORD=
